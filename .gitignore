# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments (all subprojects)
venv/
env/
.venv/
**/env/
**/.venv/
**/venv/
**/ENV/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Test and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Coverage
.coverage
.coverage.*
htmlcov/

# Django runtime files
**/db.sqlite3
**/db.sqlite3-journal
**/media/
**/staticfiles/

# Translation compilation outputs
**/locale/*/LC_MESSAGES/*.mo

# Logs and local env files
*.log
.env
.env.*

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
